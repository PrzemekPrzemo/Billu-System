# BiLLU Financial Solutions Environment Configuration
# Copy to .env and adjust values for your environment
# NEVER commit .env to version control!

# Application
APP_NAME=BiLLU
APP_URL=http://localhost
APP_DEBUG=false
APP_TIMEZONE=Europe/Warsaw
APP_LOCALE=pl

# Secret key for sessions, CSRF, encryption (generate with: php -r "echo bin2hex(random_bytes(32));")
APP_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHARS

# CORS - comma-separated list of allowed origins (use * only for development)
API_ALLOWED_ORIGINS=https://yourdomain.com
API_CORS_MAX_AGE=86400

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=billu
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Database TLS (optional). DB_SSL_CA: absolute path to CA bundle. DB_SSL_VERIFY=true enforces server cert validation.
DB_SSL_CA=
DB_SSL_VERIFY=true

# Cache (Redis)
# Set CACHE_DRIVER=null to disable caching (no-op driver, useful for development)
CACHE_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=billu:

# Mail (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=BiLLU
