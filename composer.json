{
    "name": "billu/financial-solutions",
    "description": "BiLLU Financial Solutions - system weryfikacji faktur z integracją KSeF",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "phpoffice/phpspreadsheet": "^1.29",
        "tecnickcom/tcpdf": "^6.7",
        "phpmailer/phpmailer": "^6.9",
        "chillerlan/php-qrcode": "^6.0",
        "predis/predis": "^2.2",
        "phpseclib/phpseclib": "^3.0",
        "mikehaertl/php-pdftk": "^0.13",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:security": "phpunit --testsuite security"
    }
}
